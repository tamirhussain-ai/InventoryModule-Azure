From 2c26cf3e47cc758f3245c4afbfe94c1d4ac399a0 Mon Sep 17 00:00:00 2001
From: tamirhussain-ai <tamirhussain@users.noreply.github.com>
Date: Wed, 11 Mar 2026 22:56:16 +0000
Subject: [PATCH] Fix: send Supabase anon key alongside MSAL token for backend
 compatibility

---
 .env.example            | 15 ++++++---------
 src/app/services/api.ts | 14 ++++++++------
 2 files changed, 14 insertions(+), 15 deletions(-)

diff --git a/.env.example b/.env.example
index f3e81af..19600d5 100644
--- a/.env.example
+++ b/.env.example
@@ -1,14 +1,11 @@
-# ─── Azure Entra ID (App Registration) ──────────────────────────────────────
-# Get these from: Azure Portal → App Registrations → Your App → Overview
+# ─── Azure Entra ID ───────────────────────────────────────────────────────────
 VITE_AZURE_CLIENT_ID=your-app-client-id-here
 VITE_AZURE_TENANT_ID=your-university-tenant-id-here
+VITE_REDIRECT_URI=http://localhost:5173
 
-# ─── API Backend URL ──────────────────────────────────────────────────────────
-# Phase 1: Keep pointing to Supabase backend while DB migration is in progress
-# Phase 3: Switch to your Azure App Service URL
+# ─── Backend API (Phase 1: Supabase, Phase 3: Azure App Service) ──────────────
 VITE_API_URL=https://hohuauquoerouetafaqn.supabase.co/functions/v1/make-server-5ec3cec0
 
-# ─── App Redirect URI ─────────────────────────────────────────────────────────
-# Where MSAL redirects after login. For local dev, use localhost.
-# For production, use your Azure Static Web App URL.
-VITE_REDIRECT_URI=http://localhost:5173
+# ─── Supabase Anon Key (Phase 1 only — removed in Phase 3) ───────────────────
+# Get this from: Supabase Dashboard → Project Settings → API → anon/public key
+VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
diff --git a/src/app/services/api.ts b/src/app/services/api.ts
index 039d7d2..7ec8969 100644
--- a/src/app/services/api.ts
+++ b/src/app/services/api.ts
@@ -1,26 +1,25 @@
 import { AuthService } from './auth';
 
-// Phase 1: still pointing to Supabase backend — swap to Azure App Service URL in Phase 3
 export const API_URL = import.meta.env.VITE_API_URL || '';
+const SUPABASE_ANON_KEY = import.meta.env.VITE_SUPABASE_ANON_KEY || '';
 
 export function getAuthHeaders(): Record<string, string> {
   const token = AuthService.getAccessToken();
   return {
     'Content-Type': 'application/json',
-    ...(token ? { 'Authorization': `Bearer ${token}` } : {}),
+    'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
+    ...(token ? { 'X-Session-Token': token } : {}),
   };
 }
 
 async function fetchAPI(endpoint: string, options: RequestInit = {}) {
   await AuthService.getFreshToken();
-  const token = AuthService.getAccessToken();
 
   try {
     const response = await fetch(`${API_URL}${endpoint}`, {
       ...options,
       headers: {
-        'Content-Type': 'application/json',
-        ...(token ? { 'Authorization': `Bearer ${token}` } : {}),
+        ...getAuthHeaders(),
         ...options.headers,
       },
     });
@@ -77,7 +76,10 @@ export async function uploadProductImage(file: File) {
   formData.append('file', file);
   const response = await fetch(`${API_URL}/upload-product-image`, {
     method: 'POST',
-    headers: { ...(token ? { 'Authorization': `Bearer ${token}` } : {}) },
+    headers: {
+      'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
+      ...(token ? { 'X-Session-Token': token } : {}),
+    },
     body: formData,
   });
   if (!response.ok) {
